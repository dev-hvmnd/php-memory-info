{
  "name": "dev-hvmnd/memory-info",
  "minimum-stability": "stable",
  "description": "PHP library for reading the current memory status on Linux systems",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "DevHvmnd\\MemoryInfo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DevHvmnd\\MemoryInfo\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Norman Kante",
      "email": "norman@dev-hvmnd.io"
    }
  ],
  "require": {
    "php": ">=8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5.62",
    "squizlabs/php_codesniffer": "3.*"
  },
  "scripts": {
    "test": "phpunit",
    "cs": "phpcs --standard=PSR12 src tests",
    "check": [
      "@test",
      "@cs"
    ]
  }
}
